# Daric Agency — environment variables
# Copy to `.env.local` (local) or set in your host's env (production).
# Everything is optional: the site builds and runs without any of these.

# ── Domain / deployment ───────────────────────────────────────────────
# The public origin, used for absolute OG/canonical URLs.
NEXT_PUBLIC_SITE_URL=https://daric.agency
# Base path for GitHub Pages project sites (e.g. /daric-agency). Leave empty
# for a custom domain / root deploy.
# NEXT_PUBLIC_BASE_PATH=

# ── Supabase (lead capture) ───────────────────────────────────────────
# Project Settings → API. The contact form inserts leads (source-tagged).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── Contact email (shown on the site; switch mailboxes without code) ───
# Public-facing address (footer, contact page). Defaults to daricone.web@gmail.com.
NEXT_PUBLIC_CONTACT_EMAIL=daricone.web@gmail.com

# ── Transactional email (server-side only — serverless / Edge Function) ─
# Used by src/lib/email.ts + supabase/functions/on-new-lead. Never expose to client.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Daric <daricone.web@gmail.com>
# CONTACT_EMAIL=daricone.web@gmail.com
# LEAD_NOTIFY_TO=daricone.web@gmail.com   # where new-lead alerts go (defaults to CONTACT_EMAIL)

# ── Analytics (optional, privacy-friendly, loaded only if set) ────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXX
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=daric.agency
